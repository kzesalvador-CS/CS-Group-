def calculate_quarter_grades(tentative_grades):
    """
    Calculates final quarter grades based on tentative performance.
    
    Args:
        tentative_grades (list): A list of 4 floats [T1, T2, T3, T4]
        
    Returns:
        list: Final grades for [Q1, Q2, Q3, Q4]
    """
    if len(tentative_grades) != 4:
        raise ValueError("Exactly 4 tentative grades are required.")

    final_grades = [0.0] * 4
    
    # Q1 calculation
    final_grades[0] = float(tentative_grades[0])
    
    # Q2, Q3, and Q4 calculations
    for i in range(1, 4):
        prev_q = final_grades[i-1]
        curr_t = tentative_grades[i]
        final_grades[i] = (prev_q + 2 * curr_t) / 3
        
    return final_grades
